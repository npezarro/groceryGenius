# Required: PostgreSQL connection string (Neon recommended)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Optional: Mapbox token for geocoding and map features
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Optional: Base path for subpath hosting (e.g., /grocerygenius)
# Leave empty for root hosting. No trailing slash.
BASE_PATH=/grocerygenius

# Optional: Server port (default 5000 dev, 8080 Docker)
PORT=5000

# Optional: Session secret for user authentication (random string recommended)
SESSION_SECRET=change-me-to-a-random-string

# Optional: Set to "true" to allow cookies over HTTP (dev only, never in production)
INSECURE_COOKIES=

# Optional: Admin key for protected endpoints
ADMIN_KEY=

# Optional: Enable the interactive map view (placeholder feature, disabled by default)
# Set to "true" to show the MapView component; otherwise a "Coming soon" message is displayed
VITE_ENABLE_MAP=
